{
  "interfaceFontSize": 14,
  "textFont": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif",
  "monospaceFont": "'JetBrains Mono', 'Fira Code', 'Consolas', monospace",
  "legacyEditor": false,
  "livePreview": true,
  "readableLineLength": true,
  "tabSize": 2,
  "showFrontmatter": true,
  "strictLineBreaks": false,
  "showLineNumber": true,
  "spellcheck": true,
  "autoPairBrackets": true,
  "autoPairMarkdown": true,
  "foldHeading": true,
  "foldIndent": true,
  "defaultViewMode": "preview",
  "vimMode": false,
  "newFileLocation": "current",
  "promptDelete": false,
  "showUnsupportedFiles": true,
  "alwaysUpdateLinks": true,
  "attachmentFolderPath": "Attachments",
  "showInlineTitle": true,
  "focusNewTab": true
}